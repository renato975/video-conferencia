# ===========================================
# VIDEO CONFERENCE PLATFORM - Environment
# ===========================================

# --- Backend ---
PORT=3001
NODE_ENV=development
REDIS_URL=redis://localhost:6379
CORS_ORIGIN=http://localhost:5173
MEDIA_SERVER_URL=ws://localhost:3002

# Room settings
MAX_PARTICIPANTS=50
DEFAULT_MAX_PARTICIPANTS=10

# JWT (for future auth implementation)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# --- Frontend ---
VITE_API_URL=http://localhost:3001
VITE_SOCKET_URL=http://localhost:3001
VITE_MEDIA_SERVER_URL=ws://localhost:3002

# --- Media Server ---
MEDIA_SERVER_PORT=3002
PUBLIC_IP=localhost

# STUN/TURN servers (add your own for production)
STUN_SERVERS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302

# --- Production ---
# Replace these values for production deployment
DATABASE_URL=postgresql://user:password@localhost:5432/video_conf
REDIS_URL=redis://production-redis:6379

# Example AWS production values:
# REDIS_URL=redis://prod-redis.xxxxx.0001.use1.cache.amazonaws.com:6379
# PUBLIC_IP=your-ec2-public-ip.amazonaws.com
# CORS_ORIGIN=https://your-domain.com